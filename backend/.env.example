# PBIChat — Environment Variables
# Copy this to .env and fill in your values

OPENROUTER_API_KEY=sk-or-v1-xxxxx
LLM_MODEL=anthropic/claude-sonnet-4

EXTRA_CONTEXT=

# REQUIRED — set a strong password for the settings panel
SETTINGS_PASSWORD=

# Rate limiting (requests per minute per IP, default 60)
# RATE_LIMIT_RPM=60

# CORS origins (comma-separated, default * allows all)
# In production, restrict to your Power BI domain:
# CORS_ORIGINS=https://app.powerbi.com,https://your-company.powerbi.com
# CORS_ORIGINS=*

# Supabase — license database
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxxxx

# Free tier daily query limit (default 5)
# FREE_DAILY_QUERY_LIMIT=5

# Supabase JWT secret (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=

# Stripe — billing & subscriptions
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID=price_xxxxx
