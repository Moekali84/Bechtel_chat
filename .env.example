# Bechtel_chat — Environment Variables
# Copy this to .env and fill in your values

AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/openai/v1/chat/completions
AZURE_OPENAI_API_KEY=your-azure-api-key
LLM_MODEL=gpt-5.2

# Rate limiting (requests per minute per IP, default 60)
# RATE_LIMIT_RPM=60

# CORS origins (comma-separated, default * allows all)
# In production, restrict to your Power BI domain:
# CORS_ORIGINS=https://app.powerbi.com,https://your-company.powerbi.com
# CORS_ORIGINS=*
