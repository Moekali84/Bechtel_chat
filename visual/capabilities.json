{
  "privileges": [
    {
      "name": "WebAccess",
      "essential": true,
      "parameters": ["https://*"]
    }
  ],
  "supportsLandingPage": true,
  "supportsEmptyDataView": true,
  "dataRoles": [
    {
      "name": "inlineColumns",
      "displayName": "Columns",
      "kind": "GroupingOrMeasure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "inlineColumns": { "max": 0 } },
        { "inlineColumns": { "min": 1 } }
      ],
      "table": {
        "rows": {
          "for": { "in": "inlineColumns" }
        }
      }
    }
  ],
  "objects": {
    "connection": {
      "properties": {
        "activeModelId": {
          "type": { "text": true },
          "displayName": "Active Model ID",
          "description": "UUID of the active semantic model (auto-managed)"
        }
      }
    }
  }
}
