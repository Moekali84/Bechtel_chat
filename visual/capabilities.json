{
  "privileges": [
    {
      "name": "WebAccess",
      "essential": true,
      "parameters": ["https://*"]
    }
  ],
  "supportsLandingPage": true,
  "supportsEmptyDataView": true,
  "dataRoles": [
    {
      "name": "inlineColumns",
      "displayName": "Columns",
      "kind": "GroupingOrMeasure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "inlineColumns": { "max": 0 } },
        { "inlineColumns": { "min": 1 } }
      ],
      "table": {
        "rows": {
          "for": { "in": "inlineColumns" }
        }
      }
    }
  ],
  "objects": {
    "apiSettings": {
      "properties": {
        "apiEndpoint": {
          "type": { "text": true },
          "displayName": "API Endpoint",
          "description": "Custom API endpoint URL (e.g., OpenRouter)"
        },
        "apiKey": {
          "type": { "text": true },
          "displayName": "API Key",
          "description": "API key for the custom endpoint"
        },
        "llmModel": {
          "type": { "text": true },
          "displayName": "LLM Model",
          "description": "Model name for the API"
        }
      }
    },
    "pbichat": {
      "displayName": "PBIChat history",
      "properties": {
        "historyJson": {
          "type": { "text": true },
          "displayName": "Chat history JSON",
          "description": "Serialized chat history for page navigation persistence"
        }
      }
    }
  }
}
