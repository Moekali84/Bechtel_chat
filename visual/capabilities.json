{
  "privileges": [
    {
      "name": "WebAccess",
      "essential": true,
      "parameters": ["https://*"]
    }
  ],
  "supportsLandingPage": true,
  "supportsEmptyDataView": true,
  "dataRoles": [
    {
      "name": "inlineColumns",
      "displayName": "Columns",
      "kind": "GroupingOrMeasure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        { "inlineColumns": { "max": 0 } },
        { "inlineColumns": { "min": 1 } }
      ],
      "table": {
        "rows": {
          "for": { "in": "inlineColumns" }
        }
      }
    }
  ],
  "objects": {
    "pbichat": {
      "displayName": "PBIChat history",
      "properties": {
        "historyJson": {
          "type": { "text": true },
          "displayName": "Chat history JSON",
          "description": "Serialized chat history for page navigation persistence"
        }
      }
    }
  }
}
